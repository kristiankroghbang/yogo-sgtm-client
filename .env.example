# YOGO API key (required) - get it from your YOGO dashboard
YOGO_API_KEY=

# sGTM base URL (required) - e.g. https://sst.yourdomain.com
SGTM_URL=

# Shared secret (required) - must match the secret in your sGTM client template
SGTM_SECRET=

# Poll interval in seconds (optional, default: 60)
POLL_INTERVAL=60

# Skip historical data on first run (optional, default: false)
# Set to "true" to avoid paginating through all existing records.
# Recommended for studios with many existing orders/bookings.
SKIP_INITIAL=true
